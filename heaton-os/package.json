{
  "name": "heaton-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "The Claude workspace as a warm print-craft desktop OS",
  "scripts": {
    "os": "concurrently -k -n server,web -c green,magenta \"npm:server\" \"npm:web\"",
    "server": "tsx watch server/index.ts",
    "web": "vite --open",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@fontsource/archivo-black": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@huggingface/transformers": "^4.2.0",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "mdast-util-to-string": "^4.0.0",
    "minisearch": "^7.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-rnd": "^10.5.3",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "undici": "^8.7.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
